{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "ignorePatterns": ["dist/**", "site/**", "test/fixtures/**", "fuzz/**", "profile-*.ts", "scripts/**", "src/rules/shared/evidence-propagation.ts", "src/rules/shared/finding-sheet.ts", "src/rules/shared/singularity.ts", "src/rules/shared/workflow-interaction.ts", "src/transform-stability.ts"],
  "ignoreDependencies": ["bun"],
  "dynamicallyLoaded": ["src/repository-diagnostics/imports-direct-import-diagnostics.ts", "bench/run.ts", "src/rules/shared/predicate.ts"],
  "rules": {
    "circular-dependencies": "error",
    "duplicate-exports": "error"
  },
  "health": {
    "maxCyclomatic": 20,
    "maxCognitive": 15,
    "maxCrap": 30
  },
  "duplicates": {
    "mode": "mild",
    "minLines": 5,
    "minTokens": 50
  },
  "usedClassMembers": ["clear", "has", "ids", "prerequisites"],
  "ignoreExports": [
    { "file": "src/rules/shared/diagnostic-transform.ts", "exports": ["hasAppliedTransform", "markTransformApplied", "getAppliedTransformLabels", "resetTransformTracking"] },
    { "file": "src/cli-option-resolver.ts", "exports": ["similarFlagDistanceLimit", "levenshteinDistance"] },
    { "file": "src/repo-finding-utils.ts", "exports": ["isActionsFinding", "promoteStrictFallbackSuggestions"] },
    { "file": "src/reporters-render.ts", "exports": ["affectedLocationLimit", "renderBacktickedListWithRemainder"] },
    { "file": "src/finding-grouping.ts", "exports": ["normalizeWorkflowText"] },
    { "file": "src/main.ts", "exports": ["parseArgs"] },
    { "file": "src/repository-diagnostics/index.ts", "exports": ["repositoryDiagnosticCollectors"] },
    { "file": "src/repository-similar-workflows-similarity.ts", "exports": ["collectConnectedComponents"] },
    { "file": "src/rules/shared/similar-workflow-consensus-consensus.ts", "exports": ["detectClusterInconsistency"] },
    { "file": "src/severity-promotion.ts", "exports": ["severityPromotionRules"] },
    { "file": "src/reification.ts", "exports": ["createLegacyDetails", "createBlueprintDetails", "foldDiagnosticDetails"] },
    { "file": "src/diagnostic-source.ts", "exports": ["composeDiagnosticSources", "diagnosticSourceToRef"] },
    { "file": "src/repository-diagnostics/gates.ts", "exports": ["buildDag"] },
    { "file": "src/repository-diagnostics/gate-expr.ts", "exports": ["atom", "andExpr", "orExpr", "evaluateGateExpr", "collectGates", "flattenAnd", "flattenOr", "simplifyGateExpr", "gateExprFromLegacy"] },
    { "file": "src/repository-diagnostics/semantic-resource.ts", "exports": ["ResourceId", "SemanticResource", "ResourceGetter", "ResourceResultEntry", "ResourceEvaluationObservability"] },
    { "file": "src/repository-diagnostics/resource-cache.ts", "exports": ["ResourceCache"] },
    { "file": "src/repository-diagnostics/resource-registry.ts", "exports": ["ResourceRegistry"] },
    { "file": "src/repository-diagnostics/resource-evaluator.ts", "exports": ["ResourceEvaluationError", "ResourceEvaluator", "ResourceEvaluationOptions"] },
    { "file": "src/repository-diagnostics/resources/dockerfiles.ts", "exports": ["dockerBuildTargetsResourceId", "dockerfileDataResourceId", "dockerBuildTargetsResource", "dockerfileDataResource"] },
    { "file": "src/repository-diagnostics/resources/index.ts", "exports": ["registerDefaultResources"] },
    { "file": "src/rules/shared/topo-sort.ts", "exports": ["topologicalSort"] }
  ]
}
