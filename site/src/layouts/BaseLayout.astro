---
import { withBase } from "../lib/urls";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Repository-first CI audit across major CI platforms.",
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <style>
      :root {
        color-scheme: dark;
        --bg: #0b1020;
        --panel: #12192b;
        --panel-2: #172033;
        --text: #ecf1ff;
        --muted: #9fb0d1;
        --line: #27324a;
        --accent: #7dd3fc;
        --accent-2: #93c5fd;
      }

      * {
        box-sizing: border-box;
      }

      html, body {
        margin: 0;
        padding: 0;
        background: var(--bg);
        color: var(--text);
        font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        line-height: 1.6;
      }

      a {
        color: var(--accent);
        text-decoration: none;
      }

      a:hover {
        color: var(--accent-2);
      }

      a:visited {
        color: var(--accent);
      }

      code {
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
        font-size: 0.92em;
      }

      pre {
        overflow-x: auto;
        padding: 1rem;
        border: 1px solid var(--line);
        border-radius: 8px;
        background: #0f1727;
      }

      main {
        width: min(1100px, calc(100vw - 32px));
        margin: 0 auto;
        padding: 24px 0 72px;
      }

      header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        padding: 18px 0 26px;
      }

      nav {
        display: flex;
        flex-wrap: wrap;
        gap: 14px;
      }

      .brand {
        font-weight: 700;
        letter-spacing: 0;
        color: var(--text);
      }

      .muted {
        color: var(--muted);
      }

      .panel {
        border: 1px solid var(--line);
        border-radius: 8px;
        background: var(--panel);
      }
    </style>
  </head>
  <body>
    <main>
      <header>
        <a class="brand" href={withBase("/")}>CI Perf Lint</a>
        <nav>
          <a href={withBase("/rules/")}>Rules</a>
          <a href="https://github.com/yoshi-taka/ci-perf-lint">GitHub</a>
          <a href="https://www.npmjs.com/package/@yoshi-taka/ci-perf-lint">npm</a>
        </nav>
      </header>
      <slot />
    </main>
  </body>
</html>
