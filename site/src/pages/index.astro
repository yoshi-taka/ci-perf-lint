---
import BaseLayout from "../layouts/BaseLayout.astro";
import { listRuleDocs } from "../lib/rules";
import { withBase } from "../lib/urls";

const rules = await listRuleDocs();
const featuredRules = rules.slice(0, 6);
---
<BaseLayout
  title="CI Perf Lint"
  description="Repository-first CI audit for GitHub Actions with prioritized findings and rule docs."
>
  <section class="hero">
    <p class="eyebrow">Repository-first CI audit</p>
    <h1>Find CI waste. Fix the right thing first.</h1>
    <p class="lead">
      CI Perf Lint scans workflows plus repository context, prioritizes CI waste, and returns a
      shareable improvement plan with measurement hints.
    </p>
    <div class="actions">
      <a class="primary" href={withBase("/rules/")}>Browse Rules</a>
      <a class="secondary" href="https://github.com/yoshi-taka/ci-perf-lint">View GitHub</a>
    </div>
  </section>

  <section class="grid">
    <article class="panel section">
      <h2>What it gives you</h2>
      <ul>
        <li>top findings with repository context</li>
        <li>what to fix first</li>
        <li>measurement hints for before/after verification</li>
        <li>AI-ready handoff output</li>
      </ul>
    </article>
    <article class="panel section">
      <h2>Good fit</h2>
      <ul>
        <li>CI got slow</li>
        <li>runner cost needs review</li>
        <li>workflows drifted over time</li>
        <li>you want a repo-level audit, not a single-file lint</li>
      </ul>
    </article>
  </section>

  <section class="panel section">
    <div class="section-head">
      <div>
        <p class="eyebrow">Rule docs</p>
        <h2>{rules.length} rules documented</h2>
      </div>
      <a href={withBase("/rules/")}>See all rules</a>
    </div>
    <div class="cards">
      {featuredRules.map((rule) => (
        <a class="card panel" href={withBase(`/rules/${rule.slug}/`)}>
          <h3>{rule.title}</h3>
          <p>{rule.summary}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding: 18px 0 18px;
  }

  .eyebrow {
    margin: 0 0 12px;
    color: var(--accent);
    font-size: 0.9rem;
  }

  h1 {
    margin: 0;
    max-width: 12ch;
    font-size: clamp(2.8rem, 7vw, 4.6rem);
    line-height: 0.98;
  }

  .lead {
    max-width: 760px;
    margin: 18px 0 0;
    color: var(--muted);
    font-size: 1.05rem;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 22px;
  }

  .primary,
  .secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 42px;
    padding: 0 14px;
    border: 1px solid var(--line);
    border-radius: 8px;
  }

  .primary {
    background: var(--accent);
    color: #08111f;
    border-color: transparent;
    font-weight: 700;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
    margin-top: 24px;
  }

  .section {
    padding: 24px;
  }

  .section h2 {
    margin: 0 0 12px;
    font-size: 1.35rem;
  }

  .section ul {
    margin: 0;
    padding-left: 1.2rem;
    color: var(--muted);
  }

  .section-head {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 16px;
  }

  .section-head h2 {
    margin: 0;
  }

  .cards {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
  }

  .card {
    display: block;
    padding: 18px;
  }

  .card h3 {
    margin: 0 0 8px;
    font-size: 1rem;
    color: var(--text);
  }

  .card p {
    margin: 0;
    color: var(--muted);
    font-size: 0.95rem;
  }

  @media (max-width: 900px) {
    .grid,
    .cards {
      grid-template-columns: 1fr;
    }
  }
</style>
