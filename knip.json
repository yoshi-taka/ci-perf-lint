{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignore": ["packages/ci-perf-lint/**", "test/fixtures/**", "test/arbitraries/index.ts", ".astro/**"],
  "ignoreDependencies": [],
  "ignoreBinaries": ["hyperfine"],
  "ignoreIssues": {
    "src/repository-similar-workflows-similarity.ts": ["exports"],
    "src/rules/shared/similar-workflow-consensus-consensus.ts": ["exports"],
    "src/rules/shared/evidence-propagation.ts": ["exports"]
  },
  "ignoreExportsUsedInFile": true,
  "workspaces": {
    ".": {
      "entry": [
        "stryker/stryker.core.config.mjs",
        "stryker/stryker.repo.config.mjs",
        "stryker/stryker.renderer.config.mjs",
        "stryker/stryker.rule-engine.config.mjs",
        "stryker/stryker.workflow.config.mjs",
        "site/astro.config.mjs",
        "site/src/pages/index.astro",
        "site/src/pages/rules/index.astro",
        "site/src/layouts/RuleLayout.astro",
        "bench/**/*.bench.ts",
        "bench/run.ts",
        "fuzz/**/*.mjs",
        "test/**/*.test.ts"
      ]
    }
  }
}
